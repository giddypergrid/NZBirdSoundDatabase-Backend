# ─────────────────────────────────────────────────────────────
# DjangoProject environment variables
# ─────────────────────────────────────────────────────────────
# Copy this file to `.env` (same folder as manage.py) and fill in
# real values. `.env` is gitignored. Never commit real secrets.
#
# Load order: settings.py calls python-dotenv which reads `.env`
# automatically. Existing OS env vars always win (useful in Docker).
# ─────────────────────────────────────────────────────────────

# ── Core Django ───────────────────────────────────────────────
# Generate a fresh key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=replace-me-with-a-50+-char-random-string

# "True" only for local development. MUST be False in any
# deployment that is reachable from the internet.
DJANGO_ENV=development

# Comma-separated list of hostnames/IPs Django will serve.
# Example prod: api.example.com,example.com
# Ignored when DEBUG=True (Django auto-allows localhost there).
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ── CORS (django-cors-headers) ────────────────────────────────
# Comma-separated list of allowed origins for the browser frontend.
# Example: http://localhost:5173,https://app.example.com
# Ignored when DEBUG=True (all origins allowed for local dev).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Database (PostgreSQL) ─────────────────────────────────────
# These values are used to BOTH (a) create the postgres container on
# first boot and (b) connect Django to it. They must match each other.
# In docker-compose the web service overrides DB_HOST to `db`.
DB_NAME=birdsound
DB_USER=bird
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432

# Seconds a DB connection is kept open across requests. 0 = default
# (open/close every request). 60 is a safe prod value.
DB_CONN_MAX_AGE=60
SENTRY_DSN=
# Fraction of requests sampled for performance traces (0.0 - 1.0).
# 0.1 = 10%. Lower = less Sentry quota burned.
SENTRY_TRACES_SAMPLE_RATE=0.1
# Optional: set to your git SHA / version at deploy time.
# SENTRY_RELEASE=

GRAFANA_CLOUD_TOKEN=